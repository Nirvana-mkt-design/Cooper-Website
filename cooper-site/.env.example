# Ashby read-only Posting API key used by the Careers pages (src/lib/ashby.ts).
# Get the value from Vercel project env or a team admin. Do NOT commit the real key.
VITE_ASHBY_POSTING_API_KEY=

# Optional: override the demo-request API origin (defaults to https://api.askcooper.ai)
# VITE_API_ORIGIN=

# Anti-spam demo form (stopgap). Set BOTH to route the demo form through the
# Turnstile-verified Cloudflare Worker + D1 store. Leave either empty and the
# form posts to VITE_API_ORIGIN as before (no captcha).
#   VITE_DEMO_ENDPOINT      — the Worker URL (https://cooper-demo-form.askcooper.workers.dev)
#   VITE_TURNSTILE_SITE_KEY — public Turnstile site key (0x...)
# VITE_DEMO_ENDPOINT=
# VITE_TURNSTILE_SITE_KEY=
